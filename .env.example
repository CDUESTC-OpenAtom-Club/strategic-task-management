# ===========================================
# 战略指标管理系统 - 环境变量配置模板
# ===========================================
# 使用方法：
# 1. 开发环境：cp .env.example .env.development
# 2. Mock 模式：cp .env.example .env.mock
# 3. 生产环境：通过 CI/CD 或服务器环境变量配置
# ===========================================

# -------------------------------------------
# API 配置
# -------------------------------------------
VITE_API_BASE_URL=/api
VITE_API_TARGET=http://localhost:8080

# -------------------------------------------
# 安全配置 ⚠️ 生产环境必须修改
# -------------------------------------------
# API 签名密钥（至少 32 字符）
# 生成方式：openssl rand -base64 32
VITE_API_SECRET=your_api_secret_key_at_least_32_chars_here

# 本地存储加密密钥（至少 32 字符）
VITE_STORAGE_KEY=your_storage_encryption_key_32_chars_here

# -------------------------------------------
# 功能开关
# -------------------------------------------
# Mock 模式：true=使用模拟数据，false=连接真实后端
VITE_USE_MOCK=false

# 开发工具（生产环境设为 false）
VITE_ENABLE_DEVTOOLS=true

# -------------------------------------------
# 日志配置
# -------------------------------------------
# 日志级别：debug | info | warn | error
VITE_LOG_LEVEL=info

# -------------------------------------------
# 应用信息
# -------------------------------------------
VITE_APP_TITLE=战略指标管理系统
VITE_APP_VERSION=1.0.0
