# =============================================================================
# 战略指标管理系统 (SISM) - 前端环境配置模板
# =============================================================================
# 📋 默认使用方式:
#   1. 复制: cp .env.example .env
#   2. 开发/生产都优先维护这个 .env
#   3. 只有本机需要临时覆盖时，再额外使用 .env.local
#
# 💡 标注说明:
#   [DEV] - 开发环境建议值
#   [PROD] - 生产环境建议值
#   ⚠️ - 生产环境 [必须修改] 的安全项
# =============================================================================

# -----------------------------------------------------------------------------
# 1. API 基础配置
# -----------------------------------------------------------------------------
# API 基础路径 (前端请求前缀)
VITE_API_BASE_URL=/api/v1

# 后端服务目标地址
# [DEV]: http://localhost:8080
# [PROD]: https://api.your-domain.com ⚠️
VITE_API_TARGET=http://localhost:8080

# WebSocket 服务地址 (可选)
# [DEV]: 留空 (自动根据 API 地址推导)
# [PROD]: wss://api.your-domain.com (若与 API 不同源则需填)
VITE_WS_BASE_URL=

# -----------------------------------------------------------------------------
# 2. 安全与加密 ⚠️ 生产环境必须修改
# -----------------------------------------------------------------------------
# API 签名密钥 (建议 32 位随机字符串)
# 生成参考: openssl rand -base64 32
# [DEV]: dev_api_secret_key_for_local_development_only_32chars
# [PROD]: 必须更改为唯一随机值 ⚠️
VITE_API_SECRET=dev_api_secret_key_for_local_development_only_32chars

# 本地存储 (LocalStorage/Session) 加密密钥
# [DEV]: dev_storage_encryption_key_for_local_only_32chars
# [PROD]: 必须更改为唯一随机值 ⚠️
VITE_STORAGE_KEY=dev_storage_encryption_key_for_local_only_32chars

# -----------------------------------------------------------------------------
# 3. 功能开关与调试
# -----------------------------------------------------------------------------
# Mock 模式 (是否使用本地模拟数据)
# [DEV]: true (无后端调试时启用) | false (连接真实后端)
# [PROD]: false ⚠️
VITE_USE_MOCK=false

# Vue DevTools 开发者工具
# [DEV]: true
# [PROD]: false ⚠️
VITE_ENABLE_DEVTOOLS=true

# API 健康检查 (启动时检查后端可用性)
# [DEV]: false
# [PROD]: true
VITE_ENABLE_API_HEALTH_CHECK=false

# WebSocket 通知推送 (实验性功能)
VITE_ENABLE_WEBSOCKET_NOTIFICATIONS=false

# 预警 API 开关 (部分后端环境可能未部署预警模块)
VITE_ENABLE_ALERTS_API=false

# -----------------------------------------------------------------------------
# 4. 日志配置
# -----------------------------------------------------------------------------
# 日志级别: debug | info | warn | error
# [DEV]: debug
# [PROD]: warn 或 error
VITE_LOG_LEVEL=debug

# 是否在控制台打印 API 请求/响应详情
# [DEV]: true
# [PROD]: false
VITE_LOG_API_REQUESTS=true
VITE_LOG_API_RESPONSES=true

# -----------------------------------------------------------------------------
# 5. 网络请求策略
# -----------------------------------------------------------------------------
# 请求超时时间 (毫秒)
VITE_REQUEST_TIMEOUT=30000

# 失败自动重试配置
VITE_REQUEST_RETRY_COUNT=3
VITE_REQUEST_RETRY_DELAY=1000

# -----------------------------------------------------------------------------
# 6. UI 与 应用信息
# -----------------------------------------------------------------------------
VITE_APP_TITLE=战略指标管理系统
VITE_APP_VERSION=1.0.1
VITE_APP_DESCRIPTION=Strategic Indicator Management System

# 默认界面语言与主题
VITE_DEFAULT_LOCALE=zh-CN
VITE_DEFAULT_THEME=light
VITE_DEFAULT_PAGE_SIZE=20

# ICP 备案信息
VITE_ICP_NUMBER=蜀ICP备2025177084号
VITE_ICP_LINK=https://beian.miit.gov.cn/

# -----------------------------------------------------------------------------
# 7. 开发服务器配置 (仅 Vite 本地运行有效)
# -----------------------------------------------------------------------------
VITE_DEV_SERVER_PORT=3500
VITE_DEV_AUTO_OPEN=false
