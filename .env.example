# =============================================================================
# 战略指标管理系统 - 统一环境配置模板
# =============================================================================
# 📋 使用方法：
#   开发环境：cp .env.example .env.development（使用默认值即可）
#   生产环境：cp .env.example .env.production（修改标记 ⚠️ 的配置项）
#
# 🔧 快速配置：
#   1. 复制此文件为 .env.development 或 .env.production
#   2. 根据环境修改对应的配置项（见注释说明）
#   3. 生产环境必须修改所有 ⚠️ 标记的配置
# =============================================================================

# -----------------------------------------------------------------------------
# API 配置
# -----------------------------------------------------------------------------
# API 基础路径（相对路径，用于代理）
VITE_API_BASE_URL=/api/v1

# 后端服务地址
# 开发环境：http://localhost:8080
# 生产环境：https://api.yourdomain.com ⚠️ 必须修改
VITE_API_TARGET=http://localhost:8080

# -----------------------------------------------------------------------------
# 安全配置 ⚠️ 生产环境必须修改
# -----------------------------------------------------------------------------
# API 签名密钥（至少 32 字符）
# 生成方式：openssl rand -base64 32
# 开发环境：可使用默认值
# 生产环境：必须生成新的随机密钥 ⚠️
VITE_API_SECRET=dev_api_secret_key_for_local_development_only_32chars

# 本地存储加密密钥（至少 32 字符）
# 开发环境：可使用默认值
# 生产环境：必须生成新的随机密钥 ⚠️
VITE_STORAGE_KEY=dev_storage_encryption_key_for_local_only_32chars

# -----------------------------------------------------------------------------
# 功能开关
# -----------------------------------------------------------------------------
# Mock 模式
# 开发环境：true=使用模拟数据，false=连接真实后端
# 生产环境：必须设为 false ⚠️
VITE_USE_MOCK=false

# 开发工具
# 开发环境：true
# 生产环境：必须设为 false ⚠️
VITE_ENABLE_DEVTOOLS=true

# API 健康检查（可选）
# 开发环境：false
# 生产环境：建议 true
VITE_ENABLE_API_HEALTH_CHECK=false

# -----------------------------------------------------------------------------
# 日志配置
# -----------------------------------------------------------------------------
# 日志级别：debug | info | warn | error
# 开发环境：debug 或 info
# 生产环境：warn 或 error
VITE_LOG_LEVEL=info

# API 请求日志（可选）
# 开发环境：true
# 生产环境：建议 false
VITE_LOG_API_REQUESTS=true

# API 响应日志（可选）
# 开发环境：true
# 生产环境：建议 false
VITE_LOG_API_RESPONSES=true

# -----------------------------------------------------------------------------
# 请求配置（可选）
# -----------------------------------------------------------------------------
# 请求超时时间（毫秒）
VITE_REQUEST_TIMEOUT=30000

# 请求重试次数
VITE_REQUEST_RETRY_COUNT=3

# 请求重试延迟（毫秒）
VITE_REQUEST_RETRY_DELAY=1000

# -----------------------------------------------------------------------------
# UI 配置（可选）
# -----------------------------------------------------------------------------
# 默认语言
VITE_DEFAULT_LOCALE=zh-CN

# 默认主题
VITE_DEFAULT_THEME=light

# 页面大小
VITE_DEFAULT_PAGE_SIZE=20

# -----------------------------------------------------------------------------
# 应用信息
# -----------------------------------------------------------------------------
VITE_APP_TITLE=战略指标管理系统
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Strategic Indicator Management System
