# =============================================================================
# 战略指标管理系统 - 生产环境配置
# =============================================================================

# -----------------------------------------------------------------------------
# API 配置
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=/api/v1
VITE_API_TARGET=http://localhost:8080

# -----------------------------------------------------------------------------
# 安全配置 ⚠️ 生产环境必须修改
# -----------------------------------------------------------------------------
VITE_API_SECRET=CHANGE_THIS_IN_PRODUCTION_MIN_32_CHARS
VITE_STORAGE_KEY=CHANGE_THIS_IN_PRODUCTION_MIN_32_CHARS

# -----------------------------------------------------------------------------
# CORS 配置
# -----------------------------------------------------------------------------
VITE_ALLOWED_ORIGINS=https://your-domain.com
VITE_CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
VITE_CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Requested-With

# -----------------------------------------------------------------------------
# 功能开关
# -----------------------------------------------------------------------------
VITE_USE_MOCK=false
VITE_ENABLE_DEVTOOLS=false
VITE_ENABLE_API_HEALTH_CHECK=false

# -----------------------------------------------------------------------------
# 日志配置
# -----------------------------------------------------------------------------
VITE_LOG_LEVEL=error
VITE_LOG_API_REQUESTS=false
VITE_LOG_API_RESPONSES=false

# -----------------------------------------------------------------------------
# 应用信息
# -----------------------------------------------------------------------------
VITE_APP_TITLE=战略指标管理系统
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Strategic Indicator Management System

# -----------------------------------------------------------------------------
# 请求配置
# -----------------------------------------------------------------------------
VITE_REQUEST_TIMEOUT=30000
VITE_REQUEST_RETRY_COUNT=3
VITE_REQUEST_RETRY_DELAY=1000

# -----------------------------------------------------------------------------
# UI 配置
# -----------------------------------------------------------------------------
VITE_DEFAULT_LOCALE=zh-CN
VITE_DEFAULT_THEME=light
VITE_DEFAULT_PAGE_SIZE=20
