# =============================================================================
# 战略指标管理系统 - 生产环境配置
# =============================================================================
# ⚠️ 重要提示：
# 1. 这是生产环境配置模板，请根据实际情况修改
# 2. 不要将此文件提交到 Git
# 3. 部署前必须修改所有敏感信息
# 4. 建议使用强密码和随机密钥
# =============================================================================

# -----------------------------------------------------------------------------
# API 配置
# -----------------------------------------------------------------------------
# API 基础路径（相对路径，用于代理）
VITE_API_BASE_URL=/api
# 后端服务地址（生产环境）⚠️ 必须修改为实际后端地址
VITE_API_TARGET=https://api.yourdomain.com

# -----------------------------------------------------------------------------
# 安全配置 ⚠️ 生产环境必须修改
# -----------------------------------------------------------------------------
# API 签名密钥（至少 32 字符）⚠️ 必须生成新的随机密钥
# 生成方式：openssl rand -base64 32
VITE_API_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_KEY_AT_LEAST_32_CHARACTERS
# 本地存储加密密钥（至少 32 字符）⚠️ 必须生成新的随机密钥
VITE_STORAGE_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_KEY_AT_LEAST_32_CHARACTERS

# -----------------------------------------------------------------------------
# 功能开关
# -----------------------------------------------------------------------------
# Mock 模式：生产环境必须设为 false
VITE_USE_MOCK=false
# 开发工具：生产环境必须设为 false
VITE_ENABLE_DEVTOOLS=false
# API 健康检查
VITE_ENABLE_API_HEALTH_CHECK=true

# -----------------------------------------------------------------------------
# 日志配置
# -----------------------------------------------------------------------------
# 日志级别：生产环境建议 warn 或 error
VITE_LOG_LEVEL=warn
# API 请求日志：生产环境建议关闭
VITE_LOG_API_REQUESTS=false
# API 响应日志：生产环境建议关闭
VITE_LOG_API_RESPONSES=false

# -----------------------------------------------------------------------------
# 应用信息
# -----------------------------------------------------------------------------
VITE_APP_TITLE=战略指标管理系统
VITE_APP_VERSION=1.0.0
# 应用描述
VITE_APP_DESCRIPTION=Strategic Indicator Management System

# -----------------------------------------------------------------------------
# 请求配置
# -----------------------------------------------------------------------------
# 请求超时时间（毫秒）
VITE_REQUEST_TIMEOUT=30000
# 请求重试次数
VITE_REQUEST_RETRY_COUNT=3
# 请求重试延迟（毫秒）
VITE_REQUEST_RETRY_DELAY=1000

# -----------------------------------------------------------------------------
# UI 配置
# -----------------------------------------------------------------------------
# 默认语言
VITE_DEFAULT_LOCALE=zh-CN
# 默认主题
VITE_DEFAULT_THEME=light
# 页面大小
VITE_DEFAULT_PAGE_SIZE=20
